# ============================================
# 同步任务: 模板文件同步
# ============================================

# 任务名称（页面显示用）
TASK_NAME=文件同步

# 源服务器配置 (IP)
SOURCE_HOST=xxx.xxx.xxx.xxx
SOURCE_USER=xxx
SOURCE_PATH=/home/xxx/files
SSH_PORT=22

# 目标路径 (IP)
DEST_PATH=/home/xxx/files

# 同步参数
BANDWIDTH_ENABLED=true   # 是否启用限速 (true/false)，设为 false 则不限速
BANDWIDTH_LIMIT=50000    # 限速 KB/s (50000 = ~50MB/s)
TIMEOUT=300              # 超时时间(秒)
MAX_RETRIES=3            # 最大重试次数
